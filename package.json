	"license": "MIT",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"workspaces": {
		"packages": [
			"packages/*"
		]
	},
	"scripts": {
		"server": "cd packages/server && pnpm dev",
		"web": "cd packages/web && pnpm dev",
